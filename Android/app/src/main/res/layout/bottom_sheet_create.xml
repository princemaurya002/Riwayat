<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create New"
        android:textColor="@color/brand_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_product"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Add New Product"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="28dp"
        app:icon="@mipmap/ic_launcher"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_ai_marketing"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="AI Description &amp; SEO"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="28dp"
        app:icon="@mipmap/ic_launcher"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_add_product" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_translate"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="Vernacular Translation"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_secondary"
        app:cornerRadius="28dp"
        app:icon="@mipmap/ic_launcher"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_ai_marketing" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_social_post"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="Create Social Post"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_primary_dark"
        app:cornerRadius="28dp"
        app:icon="@mipmap/ic_launcher"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_translate" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_log_expense"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:text="Log an Expense"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="28dp"
        app:icon="@mipmap/ic_launcher"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_social_post" />

</androidx.constraintlayout.widget.ConstraintLayout>

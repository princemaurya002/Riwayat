<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Rewayat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="android:navigationBarColor">@color/brand_primary</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.Rewayat.Splash" parent="Theme.Rewayat">
        <item name="android:windowBackground">@color/brand_primary</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>